{
  "name": "dbt + Airflow + PostgreSQL",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {}
  },
  "postCreateCommand": "pip install -r refs/edu/requirements.txt",
  "forwardPorts": [8081, 5433],
  "portsAttributes": {
    "8081": { "label": "Airflow UI" },
    "5433": { "label": "PostgreSQL" }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "innoverio.vscode-dbt-power-user"
      ]
    }
  }
}